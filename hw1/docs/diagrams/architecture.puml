@startuml
skinparam componentStyle rectangle
skinparam shadowing false

package "Windows Desktop Client" {
  [UI Layer\nWPF/WinUI 页面与控件] as UI
  [Application Layer\n用例服务、财报摘要与提醒调度] as App
  [Domain Layer\nStock, Watchlist, FinancialSummary, AlertRule] as Domain
  [Infrastructure Layer\n行情/财务适配器、SQLite、通知] as Infra
}

database "SQLite\nwatchlist.db" as DB
cloud "Market Data APIs\nAKShare/东方财富/新浪/腾讯" as API
cloud "Financial Data APIs\nAKShare/BaoStock/公开财报" as FAPI
queue "Timer/Background Worker\n5s-60s polling" as Timer
node "Windows Toast/Dialog" as Toast

UI --> App
App --> Domain
App --> Infra
Infra --> DB
Infra --> API
Infra --> FAPI
Timer --> App
Infra --> Toast
@enduml
