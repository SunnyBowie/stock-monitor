@startuml
object "1 用户" as User
object "2 JavaFX MainController" as UI
object "3 MarketUniverseService" as Universe
object "4 EastMoneyMarketDataProvider" as Provider
object "5 MarketQuote Cache" as Cache

User --> UI : 1. 启动/搜索股票
UI --> Universe : 2. start / setQuery
Universe --> Provider : 3. marketPage(page, 200)
Provider --> Universe : 4. MarketPage(total=5530)
Universe --> Cache : 5. merge quotes
Cache --> UI : 6. visibleQuotes
UI --> Provider : 7. quote / intraday / candles / F10
UI --> User : 8. 原生窗口展示详情
@enduml
