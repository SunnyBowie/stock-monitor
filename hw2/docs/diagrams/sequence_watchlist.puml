@startuml
actor User as 用户
boundary UI as "JavaFX MainController"
control Universe as "MarketUniverseService"
control WatchlistService as "WatchlistService"
interface Provider as "MarketDataProvider"
entity Page as "MarketPage"
entity Quote as "MarketQuote"

用户 -> UI : 启动软件
UI -> Universe : start()
loop 分页导入全 A 股
  Universe -> Provider : marketPage(page, 200)
  Provider --> Universe : MarketPage(total, quotes)
  Universe -> Page : merge(quotes)
  Universe --> UI : visibleQuotes 更新
end
用户 -> UI : 搜索股票代码/简称
UI -> Universe : setQuery(keyword)
Universe --> UI : 过滤后的行情列表
用户 -> UI : 点击股票
UI -> WatchlistService : add(stock)
UI --> 用户 : 右侧详情刷新
@enduml
